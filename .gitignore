# --- PYTHON ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- PYINSTALLER ---
# PyInstaller outputs MUST go to /dist and /build-temp
dist/
build-temp/
build/build/
build/dgm_mat/
*.toc
*.pkg
*.pyz
xref-*.html
warn-*.txt

# Preserve important build configs
!build/*.spec
!build/windows/version_info.txt

# --- VIRTUAL ENVIRONMENTS ---
venv/
.env/
.venv/
env/

# --- ENVIRONMENT & SECRETS ---
.env
.env.*
*.env
secrets/
vault/

# --- LOGS & RUNTIME ---
logs/
*.log
.runtime/
runtime/
storage/runtime/
storage/memory/
storage/cognition/
storage/governance/
storage/federation/
storage/sandbox/
storage/providers/
storage/logs/
storage/snapshots/
storage/temp/
data/
worktrees/
tmp/
temp/

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# --- LOCAL DEVELOPMENT REPOS ---
repositories/

# --- MODELS & DATA ---
models/
*.gguf
*.bin
*.safetensors
*.db
*.sqlite
*.sqlite3
qdrant_storage/
neo4j/data/
neo4j/logs/
redis-data/
postgres-data/

# --- BUILD OUTPUTS ---
release/
artifacts/
*.exe
*.apk
*.aab
*.zip
*.rar
*.7z

# --- WEB & DOCKER ---
node_modules/
docker-data/
playwright/.cache/
playwright/browser_data/
grafana-data/
prometheus-data/
loki-data/

# --- USER DATA ---
user_uploads/
conversation_exports/
provider_sessions/
browser_profiles/

# --- CRITICAL: PREVENT ABSOLUTE PATH TRACKING ---
[a-zA-Z]:/*
/*:/*
