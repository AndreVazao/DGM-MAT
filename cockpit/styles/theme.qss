QWidget {
    background-color: #111111;
    color: #EAEAEA;
    font-size: 13px;
}

QFrame {
    border: 1px solid #2A2A2A;
    border-radius: 8px;
}

QPushButton {
    background-color: #1E1E1E;
    border: 1px solid #3A3A3A;
    padding: 6px;
    border-radius: 6px;
}

QPushButton:hover {
    background-color: #2C2C2C;
}

QTextEdit {
    background-color: #0D0D0D;
    border: 1px solid #2A2A2A;
}

QListWidget {
    background-color: #0D0D0D;
    border: 1px solid #2A2A2A;
}
